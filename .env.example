# text-to-cad-dockerkit — environment configuration
#
# Copy this file to .env and adjust values before running docker compose.

# Upstream release tag to build from.
# Check latest at: https://github.com/earthtojake/text-to-cad/tags
TEXT_TO_CAD_VERSION=0.3.7

# UID and GID of the host user so generated files in /workspace
# have the correct ownership.  Run `id -u` and `id -g` to see yours.
LOCAL_UID=1000
LOCAL_GID=1000

# Port mappings — map container ports to host ports.
# ttyd browser terminal.
OPENCODE_TTYD_PORT=3001
# CAD Viewer HTTP server.
VIEWER_HOST_PORT=3002

# Name of the named volume used for /workspace persistence.
# Change only if you need to isolate multiple workbench instances.
WORKSPACE_VOLUME_NAME=cad-workbench-workspace
